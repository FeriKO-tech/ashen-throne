        <div class="faq-cat-card" data-target="#faq-account" role="button" tabindex="0" aria-label="Jump to Account questions">
          <div class="faq-cat-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div class="faq-cat-name">Account</div>
        </div>
        <div class="faq-cat-card" data-target="#faq-technical" role="button" tabindex="0" aria-label="Jump to Technical questions">
          <div class="faq-cat-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <div class="faq-cat-name">Technical</div>
        </div>
        <div class="faq-cat-card" data-target="#faq-gameplay" role="button" tabindex="0" aria-label="Jump to Gameplay questions">
          <div class="faq-cat-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.5 10c-.83 0-1.5-.67-1.5-1.5v-5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5v5c0 .83-.67 1.5-1.5 1.5z"/><path d="M20.5 10H19V8.5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/><path d="M9.5 14c.83 0 1.5.67 1.5 1.5v5c0 .83-.67 1.5-1.5 1.5S8 21.33 8 20.5v-5c0-.83.67-1.5 1.5-1.5z"/><path d="M3.5 14H5v1.5c0 .83-.67 1.5-1.5 1.5S2 16.33 2 15.5 2.67 14 3.5 14z"/></svg>
          </div>
          <div class="faq-cat-name">Gameplay</div>
        </div>
      </div>

      <!-- ACCORDION -->
      <div class="faq-accordion">

        <div class="faq-group" id="faq-account">
          <div class="faq-group-title">Account</div>
          <div class="faq-item"><div class="faq-question" role="button" tabindex="0" aria-expanded="false"><span class="faq-question-text">How do I reset my password?</span><span class="faq-icon" aria-hidden="true">+</span></div><div class="faq-answer" role="region"><div class="faq-answer-inner">Password reset functionality will be enabled when the launcher officially releases. If you lose access to your account before then, please contact support.</div></div></div>
          <div class="faq-item"><div class="faq-question" role="button" tabindex="0" aria-expanded="false"><span class="faq-question-text">Can I change my username?</span><span class="faq-icon" aria-hidden="true">+</span></div><div class="faq-answer" role="region"><div class="faq-answer-inner">Username changes will be supported via the Account settings page upon the game's full release. Please choose your initial war name carefully during registration.</div></div></div>
          <div class="faq-item"><div class="faq-question" role="button" tabindex="0" aria-expanded="false"><span class="faq-question-text">How do I enable two-factor authentication?</span><span class="faq-icon" aria-hidden="true">+</span></div><div class="faq-answer" role="region"><div class="faq-answer-inner">Two-factor authentication (2FA) will be available in Account Settings prior to the beta launch. We strongly recommend enabling it once the security portal goes live.</div></div></div>
          <div class="faq-item"><div class="faq-question" role="button" tabindex="0" aria-expanded="false"><span class="faq-question-text">I was banned — what do I do?</span><span class="faq-icon" aria-hidden="true">+</span></div><div class="faq-answer" role="region"><div class="faq-answer-inner">Submit a ban appeal via <a href="mailto:support@ironveilstudios.com">support@ironveilstudios.com</a> with your account username and a detailed description. Appeals are reviewed within 5 business days.</div></div></div>
        </div>

        <div class="faq-group" id="faq-technical">
          <div class="faq-group-title">Technical</div>
          <div class="faq-item"><div class="faq-question" role="button" tabindex="0" aria-expanded="false"><span class="faq-question-text">The launcher is not available for download. Why?</span><span class="faq-icon" aria-hidden="true">+</span></div><div class="faq-answer" role="region"><div class="faq-answer-inner">The game client is currently in final network testing. Pre-downloads will open shortly before the beta begins. Stay tuned to your registered email for updates.</div></div></div>
          <div class="faq-item"><div class="faq-question" role="button" tabindex="0" aria-expanded="false"><span class="faq-question-text">Where can I check server requirements?</span><span class="faq-icon" aria-hidden="true">+</span></div><div class="faq-answer" role="region"><div class="faq-answer-inner">Full server locations and technical network requirements will be posted on the <a href="/news.html">dispatch board</a> once we officially announce the stress-test dates.</div></div></div>
          <div class="faq-item"><div class="faq-question" role="button" tabindex="0" aria-expanded="false"><span class="faq-question-text">How do I report website issues?</span><span class="faq-icon" aria-hidden="true">+</span></div><div class="faq-answer" role="region"><div class="faq-answer-inner">If you encounter issues with registration or layout bugs, email <a href="mailto:bugs@ironveilstudios.com">bugs@ironveilstudios.com</a> with your browser details and a screenshot.</div></div></div>
          <div class="faq-item"><div class="faq-question" role="button" tabindex="0" aria-expanded="false"><span class="faq-question-text">What are the minimum system requirements?</span><span class="faq-icon" aria-hidden="true">+</span></div><div class="faq-answer" role="region"><div class="faq-answer-inner"><strong style="color:var(--text-primary);">OS:</strong> Windows 10 64-bit &nbsp;·&nbsp; <strong style="color:var(--text-primary);">CPU:</strong> Intel i5-6600 / AMD Ryzen 5 1600 &nbsp;·&nbsp; <strong style="color:var(--text-primary);">RAM:</strong> 8 GB &nbsp;·&nbsp; <strong style="color:var(--text-primary);">GPU:</strong> GTX 1060 / AMD RX 580 &nbsp;·&nbsp; <strong style="color:var(--text-primary);">Storage:</strong> 8.4 GB SSD. See the <a href="/download.html">download page</a> for full specs.</div></div></div>
        </div>

        <div class="faq-group" id="faq-gameplay">
          <div class="faq-group-title">Gameplay (Intended Design)</div>
          <div class="faq-item"><div class="faq-question" role="button" tabindex="0" aria-expanded="false"><span class="faq-question-text">How will the PvP flagging system work?</span><span class="faq-icon" aria-hidden="true">+</span></div><div class="faq-answer" role="region"><div class="faq-answer-inner">Our intended design allows any player to be flagged for PvP outside safe zones. We are currently tuning a 30-second cooldown for unflagging. Final rules will be tested during Alpha.</div></div></div>
          <div class="faq-item"><div class="faq-question" role="button" tabindex="0" aria-expanded="false"><span class="faq-question-text">How will I join a guild?</span><span class="faq-icon" aria-hidden="true">+</span></div><div class="faq-answer" role="region"><div class="faq-answer-inner">Upon the launch of the Guild System, players will access a dedicated UI panel to browse alliances by name or tag. Guild warfare mechanics are slated for our second beta phase.</div></div></div>
          <div class="faq-item"><div class="faq-question" role="button" tabindex="0" aria-expanded="false"><span class="faq-question-text">What happens when I die in PvP?</span><span class="faq-icon" aria-hidden="true">+</span></div><div class="faq-answer" role="region"><div class="faq-answer-inner">Current design documents state that death will result in gear durability loss and dropped resources. We aim to avoid permanent gear loss unless holding cursed loot. We will validate this heavily in testing.</div></div></div>
          <div class="faq-item"><div class="faq-question" role="button" tabindex="0" aria-expanded="false"><span class="faq-question-text">Will the Voidrift region be available at launch?</span><span class="faq-icon" aria-hidden="true">+</span></div><div class="faq-answer" role="region"><div class="faq-answer-inner">The Voidrift region is planned as our primary endgame zone. Access will require completing the &ldquo;Rift Seeker&rdquo; campaign, projected to be available in the late stages of Beta.</div></div></div>
        </div>

      </div>
    </section>

    <!-- CONTACT SECTION -->
    <section class="support-contact" style="margin-top:5rem;" aria-labelledby="contact-heading">
      <div class="section-label reveal">Direct Help</div>
      <h2 class="section-title reveal" id="contact-heading" style="margin-bottom:2.5rem;">Still Need Help?</h2>
      <div class="support-contact-grid">
        <div class="support-card reveal">
          <div class="support-card-icon"><svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg></div>
          <div class="support-card-title">Email Support</div>
          <div class="support-card-handle">support@ironveilstudios.com</div>
          <div class="support-card-desc">Response within 24 hours on business days. Include your account username for faster resolution.</div>
          <a href="mailto:support@ironveilstudios.com" class="btn-ghost">Send Email</a>
        </div>
        <div class="support-card reveal reveal-delay-1">
          <div class="support-card-icon"><svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 18h16"/><path d="M7 14h10"/><path d="M10 10h4"/><path d="M12 3v3"/><path d="M8 6h8"/></svg></div>
          <div class="support-card-title">Status &amp; Updates</div>
          <div class="support-card-handle">Live server bulletin</div>
          <div class="support-card-desc">Track maintenance windows, patch notes, and live event timing from the official dispatch feed.</div>
          <a href="/news.html#serverStatus" class="btn-ghost">Open Bulletin</a>
        </div>
        <div class="support-card reveal reveal-delay-2">
          <div class="support-card-icon"><svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M9 9c0-1.657 1.343-3 3-3s3 1.343 3 3-1.343 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></div>
          <div class="support-card-title">Bug Reports</div>
          <div class="support-card-handle">bugs@ironveilstudios.com</div>
          <div class="support-card-desc">Found something broken? Help us improve the game. Detailed reports with reproduction steps are rewarded.</div>
          <a href="mailto:bugs@ironveilstudios.com" class="btn-ghost">Report a Bug</a>
        </div>
      </div>
    </section>

    <!-- ═══════ CONTACT FORM ═══════ -->
    <section style="margin-top:4rem;">
      <div class="section-label reveal" style="justify-content:center;">Direct Line</div>
      <h2 class="reveal reveal-delay-1" style="font-family:var(--font-heading);font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;color:var(--text-primary);text-align:center;margin-bottom:2rem;">Send a Message</h2>
      <p class="reveal reveal-delay-1" style="font-family:var(--font-body);font-size:1rem;color:var(--text-muted);text-align:center;max-width:600px;margin:0 auto 2.5rem;font-style:italic;">Can&rsquo;t find your answer above? Reach us directly. We respond within 24 hours.</p>

      <form id="supportContactForm" class="reveal reveal-delay-2" style="max-width:640px;margin:0 auto;display:flex;flex-direction:column;gap:1.25rem;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;">
          <div>
            <label for="contactName" style="font-family:var(--font-ui);font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--accent-gold);display:block;margin-bottom:0.5rem;">Name</label>
            <input type="text" id="contactName" name="name" required placeholder="Your name"
              style="width:100%;padding:0.85rem 1rem;background:rgba(255,255,255,0.03);border:1px solid rgba(201,168,76,0.15);color:var(--text-primary);font-family:var(--font-body);font-size:1rem;transition:border-color 0.3s;outline:none;"
              onfocus="this.style.borderColor='rgba(201,168,76,0.4)'" onblur="this.style.borderColor='rgba(201,168,76,0.15)'">
          </div>
          <div>
            <label for="contactEmail" style="font-family:var(--font-ui);font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--accent-gold);display:block;margin-bottom:0.5rem;">Email</label>
            <input type="email" id="contactEmail" name="email" required placeholder="your@email.com"
              style="width:100%;padding:0.85rem 1rem;background:rgba(255,255,255,0.03);border:1px solid rgba(201,168,76,0.15);color:var(--text-primary);font-family:var(--font-body);font-size:1rem;transition:border-color 0.3s;outline:none;"
              onfocus="this.style.borderColor='rgba(201,168,76,0.4)'" onblur="this.style.borderColor='rgba(201,168,76,0.15)'">
          </div>
        </div>

        <div>
          <label for="contactCategory" style="font-family:var(--font-ui);font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--accent-gold);display:block;margin-bottom:0.5rem;">Category</label>
          <select id="contactCategory" name="category" required
            style="width:100%;padding:0.85rem 1rem;background:rgba(255,255,255,0.03);border:1px solid rgba(201,168,76,0.15);color:var(--text-primary);font-family:var(--font-body);font-size:1rem;transition:border-color 0.3s;outline:none;appearance:none;-webkit-appearance:none;cursor:pointer;"
            onfocus="this.style.borderColor='rgba(201,168,76,0.4)'" onblur="this.style.borderColor='rgba(201,168,76,0.15)'">
            <option value="" disabled selected style="color:var(--text-dim);">Select a category</option>
            <option value="account">Account &amp; Login</option>
            <option value="technical">Technical Issue</option>
            <option value="bug">Bug Report</option>
            <option value="billing">Billing &amp; Purchases</option>
            <option value="feedback">General Feedback</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div>
          <label for="contactMessage" style="font-family:var(--font-ui);font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--accent-gold);display:block;margin-bottom:0.5rem;">Message</label>
          <textarea id="contactMessage" name="message" required rows="5" placeholder="Describe your issue or question..."
            style="width:100%;padding:0.85rem 1rem;background:rgba(255,255,255,0.03);border:1px solid rgba(201,168,76,0.15);color:var(--text-primary);font-family:var(--font-body);font-size:1rem;resize:vertical;min-height:120px;transition:border-color 0.3s;outline:none;"
            onfocus="this.style.borderColor='rgba(201,168,76,0.4)'" onblur="this.style.borderColor='rgba(201,168,76,0.15)'"></textarea>
        </div>

        <button type="submit" class="btn-primary" style="align-self:center;margin-top:0.5rem;min-width:220px;">Submit Request</button>
      </form>

      <div id="contactSuccess" style="display:none;text-align:center;max-width:640px;margin:2rem auto;padding:2rem;border:1px solid rgba(201,168,76,0.2);background:rgba(201,168,76,0.03);">
        <div style="font-size:2rem;margin-bottom:0.75rem;">&#10003;</div>
        <h3 style="font-family:var(--font-heading);font-size:1.2rem;color:var(--text-primary);margin-bottom:0.5rem;">Message Received</h3>
        <p style="font-family:var(--font-body);font-size:1rem;color:var(--text-muted);font-style:italic;">Your request has been recorded. We&rsquo;ll respond to your email within 24 hours.</p>
      </div>
    </section>

  </div>
</section>

<script>
(function () {
  'use strict';
  document.querySelectorAll('.faq-item').forEach(function (item) {
    var question = item.querySelector('.faq-question');
    var answer   = item.querySelector('.faq-answer');
    var icon     = item.querySelector('.faq-icon');
    if (!question || !answer || !icon) return;
    function toggle() {
      var isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item.open').forEach(function (o) {
        o.classList.remove('open');
        o.querySelector('.faq-answer').style.maxHeight = '0';
        o.querySelector('.faq-icon').textContent = '+';
        o.querySelector('.faq-question').setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('open');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        icon.textContent = '\u00D7';
        question.setAttribute('aria-expanded', 'true');
      }
    }
    question.addEventListener('click', toggle);
    question.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }
    });
  });
  document.querySelectorAll('.faq-cat-card[data-target]').forEach(function (card) {
    function scrollTo() {
      var target = document.querySelector(card.getAttribute('data-target'));
      if (target) {
        target.scrollIntoView({
          behavior: window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth',
          block: 'start'
        });
      }
    }
    card.addEventListener('click', scrollTo);
    card.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); scrollTo(); }
    });
  });

  (function initSupportSearch() {
    var input   = document.getElementById('supportSearchInput');
    var button  = document.getElementById('supportSearchButton');
    var emptyEl = document.getElementById('supportSearchEmpty');
    if (!input) return;

    function doSearch() {
      var query = input.value.trim().toLowerCase();
      if (!query) {
        document.querySelectorAll('.faq-group').forEach(function (g) { g.hidden = false; });
        document.querySelectorAll('.faq-item').forEach(function (i) { i.hidden = false; });
        if (emptyEl) emptyEl.hidden = true;
        return;
      }

      var anyVisible = false;
      document.querySelectorAll('.faq-group').forEach(function (group) {
        var groupVisible = false;
        group.querySelectorAll('.faq-item').forEach(function (item) {
          var qText = (item.querySelector('.faq-question-text') || {}).textContent || '';
          var aText = (item.querySelector('.faq-answer-inner') || {}).textContent || '';
          var match = qText.toLowerCase().indexOf(query) !== -1 || aText.toLowerCase().indexOf(query) !== -1;
          item.hidden = !match;
          if (match) { groupVisible = true; anyVisible = true; }
        });
        group.hidden = !groupVisible;
      });

      if (emptyEl) emptyEl.hidden = anyVisible;
    }

    button.addEventListener('click', doSearch);
    input.addEventListener('keydown', function (e) {
      if (e.key === 'Enter') { e.preventDefault(); doSearch(); }
    });
    input.addEventListener('input', function () {
      if (input.value.trim() === '') doSearch();
    });
  }());

  /* ── Contact Form ── */
  (function initContactForm() {
    var form    = document.getElementById('supportContactForm');
    var success = document.getElementById('contactSuccess');
    if (!form) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var data = {
        name:     document.getElementById('contactName').value.trim(),
        email:    document.getElementById('contactEmail').value.trim(),
        category: document.getElementById('contactCategory').value,
        message:  document.getElementById('contactMessage').value.trim(),
        date:     new Date().toISOString()
      };

      /* Save to localStorage as demo persistence */
      try {
        var tickets = JSON.parse(localStorage.getItem('at_support_tickets') || '[]');
        tickets.push(data);
        localStorage.setItem('at_support_tickets', JSON.stringify(tickets));
      } catch (err) { /* silent */ }

      form.style.transition = 'opacity 0.3s';
      form.style.opacity = '0';
      form.style.pointerEvents = 'none';
      setTimeout(function () {
        form.style.display = 'none';
        if (success) success.style.display = 'block';
      }, 300);
    });
  }());
}());
</script>
