    </div>

    <!-- FAQ SECTION -->
    <section id="faq-section" aria-labelledby="faq-heading">
      <div class="section-label reveal">Common Questions</div>
      <h2 class="section-title reveal" id="faq-heading">Frequently Asked</h2>

      <!-- CATEGORY NAVIGATION -->
