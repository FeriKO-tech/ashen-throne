<!-- ═══════ SUPPORT CONTENT ═══════ -->
<section class="news-page" style="padding:5rem 0 6rem;">
  <div class="news-page-bg"></div>
  <div class="container">

    <!-- SEARCH -->
    <div class="support-search reveal">
      <div class="support-search-row">
        <input id="supportSearchInput" type="search" placeholder="Search for help..." aria-label="Search support articles">
        <button class="btn-primary" id="supportSearchButton" type="button" aria-label="Search">Search</button>
      </div>
