<!DOCTYPE html>
<html lang="en">
<head>
  {% include "partials/seo-head.njk" %}
</head>
<body class="page-loading{{ (' ' + bodyClass) if bodyClass else '' }}">
<div id="preloader" aria-hidden="true">
  <div class="pl-emblem">
    <svg width="90" height="90" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M50 5 L58 30 L85 30 L63 47 L72 75 L50 58 L28 75 L37 47 L15 30 L42 30Z" stroke="#c9a84c" stroke-width="1.5" fill="none" opacity="0.7"/>
      <circle cx="50" cy="50" r="30" stroke="#c9a84c" stroke-width="0.8" fill="none" opacity="0.35"/>
      <circle cx="50" cy="50" r="42" stroke="#c9a84c" stroke-width="0.5" fill="none" opacity="0.2"/>
      <path d="M50 8 L50 20 M50 80 L50 92 M8 50 L20 50 M80 50 L92 50" stroke="#c9a84c" stroke-width="0.5" opacity="0.3"/>
      <circle cx="50" cy="50" r="4" fill="#c9a84c" opacity="0.6"/>
    </svg>
  </div>
  <p class="pl-studio">Ironveil Studios Presents</p>
  <div class="pl-bar-wrap"><div class="pl-bar" id="plBar"></div></div>
</div>

<div id="cursor"></div>
<div id="cursor-dot"></div>

<a href="#main-content" class="skip-link">Skip to main content</a>
{% include "partials/nav.njk" %}

<main id="main-content" tabindex="-1">
{{ content | safe }}
</main>

<div class="section-divider"></div>

{% include "partials/footer.njk" %}

<div id="page-transition"></div>
<button id="back-to-top" aria-label="Back to top">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
       stroke-linecap="round" stroke-linejoin="round">
    <path d="M18 15 L12 9 L6 15"/>
  </svg>
</button>

<script src="/assets/js/main.min.js" defer></script>
{%- if pageScripts %}
{%- for src in pageScripts %}
<script src="{{ src }}" defer></script>
{%- endfor %}
{%- endif %}
{%- if inlineScript %}
<script>{{ inlineScript | safe }}</script>
{%- endif %}

</body>
</html>
