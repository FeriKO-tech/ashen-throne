{# ═══════════════════════════════════════════════════════════════════════════
   NAV PARTIAL
   - nav.js data drives the link list
   - Active state: set `pageSlug` in page front matter matching a nav item slug
   - News article pages: any URL under /news/* (excluding /news.html itself)
     auto-highlights the News link without needing pageSlug set on each article
   ═══════════════════════════════════════════════════════════════════════════ #}

{%- set _isNewsArticle = ("/news/" in page.url) and (page.url != "/news.html") -%}

<nav class="nav" id="nav" aria-label="Main navigation">
  <a href="/index.html" class="nav-logo">Ashen Throne</a>

  <ul class="nav-links">
    {%- for item in nav -%}
    {%- set _active = (item.slug == pageSlug) or (item.slug == "news" and _isNewsArticle) -%}
    <li>
      <a href="{{ item.href }}"{% if _active %} class="active"{% endif %}
        {% if item.href == page.url %} aria-current="page"{% endif %}>
        {{ item.label }}
      </a>
    </li>
    {%- endfor -%}
  </ul>

  <a href="/download.html" class="nav-cta">Play Free</a>

  <button class="cart-trigger" id="cartTrigger" aria-label="Open cart">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="18" height="18"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
    <span class="cart-badge" id="cartBadge"></span>
  </button>

  <div class="hamburger" id="hamburger" role="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobileMenu" tabindex="0">
    <span></span><span></span><span></span>
  </div>
</nav>

<div class="cart-backdrop" id="cartBackdrop"></div>

<div class="cart-panel" id="cartPanel" role="dialog" aria-modal="true" aria-label="War Chest">
  <div class="cart-panel-head">
    <h3>War Chest</h3>
    <button class="cart-close" id="cartClose" aria-label="Close cart">&times;</button>
  </div>
  <div class="cart-items" id="cartItems"></div>
  <div class="cart-foot">
    <div class="cart-total-row">
      <span class="cart-total-label">Total</span>
      <div class="cart-total-val"><span class="cart-total-sym">&#x2B21;</span><span id="cartTotal">0</span></div>
    </div>
    <button class="btn-primary cart-checkout" type="button">Proceed to Checkout</button>
  </div>
</div>

<div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Mobile navigation" aria-hidden="true">
  {%- for item in nav -%}
  {%- set _active = (item.slug == pageSlug) or (item.slug == "news" and _isNewsArticle) -%}
  <a href="{{ item.href }}"
     {% if _active %} class="active"{% endif %}
     onclick="closeMobile()">
    {{ item.label }}
  </a>
  {%- endfor -%}
  <a href="/account.html" style="color:var(--accent-gold);" onclick="closeMobile()">Login / Register</a>
</div>
