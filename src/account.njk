    <!-- Logged-in dashboard (shown after successful auth) -->
    <div class="auth-dashboard" id="authDashboard" style="display:none;">
      <div class="auth-dashboard-inner">
        <div class="auth-dashboard-avatar" id="authAvatar" aria-hidden="true">?</div>
