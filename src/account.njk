      <form id="registerForm" style="display:none;" novalidate>
        <div class="auth-field">
          <label for="regUser">Username</label>
          <input class="auth-input" type="text" id="regUser" placeholder="Choose a war name" autocomplete="username" required minlength="3" maxlength="20"/>
          <span class="auth-error" id="regUserErr"></span>
        </div>
        <div class="auth-field">
          <label for="regEmail">Email</label>
          <input class="auth-input" type="email" id="regEmail" placeholder="warrior@realm.com" autocomplete="email" required/>
          <span class="auth-error" id="regEmailErr"></span>
        </div>
        <div class="auth-field">
          <label for="regPass">Password</label>
          <div class="auth-pass-wrap">
            <input class="auth-input" type="password" id="regPass" placeholder="A stronger oath" autocomplete="new-password" required minlength="8"/>
