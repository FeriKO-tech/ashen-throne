          <span class="auth-error" id="regPassErr"></span>
        </div>
        <div class="auth-field">
          <label for="regConfirm">Confirm Password</label>
          <div class="auth-pass-wrap">
            <input class="auth-input" type="password" id="regConfirm" placeholder="Repeat the oath" autocomplete="new-password" required/>
            <button class="auth-eye" type="button" data-eye="regConfirm" aria-label="Toggle password visibility">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <span class="auth-error" id="regConfirmErr"></span>
        </div>
