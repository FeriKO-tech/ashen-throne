<script>
(function () {
  'use strict';
  var filtersEl = document.getElementById('shopFilters');
  if (!filtersEl) return;
  var buttons = filtersEl.querySelectorAll('[data-filter]');
  var items   = document.querySelectorAll('.shop-item[data-category]');
  function setFilter(f) {
    buttons.forEach(function (b) {
      var active = b.getAttribute('data-filter') === f;
      b.classList.toggle('btn-primary', active);
      b.classList.toggle('btn-ghost',   !active);
    });
    items.forEach(function (item) {
      item.style.display = (f === 'all' || item.getAttribute('data-category') === f) ? '' : 'none';
    });
  }
  buttons.forEach(function (b) {
    b.addEventListener('click', function () { setFilter(b.getAttribute('data-filter')); });
  });
  setFilter('all');
}());
</script>
